# HRMS Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── Database (Neon PostgreSQL) ──
# Use the asyncpg scheme for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# ── JWT ──
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──
# Comma-separated list of origins, or ["*"] for all
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Login ID ──
# Company prefix for employee login IDs (e.g. "OI" for Odoo India)
COMPANY_LOGIN_PREFIX=OI
